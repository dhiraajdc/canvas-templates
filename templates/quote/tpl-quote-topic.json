{
  "meta": {"template_id":"quote-topic-v1","intent":"quote","mode":"topic","style":"editorial_topic","version":"3.1","total_frames":270,"fps":30},
  "canvas": {"ratio":"4:5","background":"#0A0A0C"},
  "brand": {
    "logo":"MINDFUL·CO",
    "colors":{"primary":"#C8A96E","background":"#0A0A0C","text":"#F5F2EB","muted":"#7A7468","surface":"#111114"},
    "fonts":{"display":"Bebas Neue","serif":"Playfair Display","sans":"DM Sans","mono":"DM Mono","grotesk":"Space Grotesk"}
  },
  "data": {"quote_text":"Culture eats strategy for breakfast.","author_name":"Peter Drucker","topic":"Leadership","source":"Management Challenges, 1999"},
  "layers": [
    {"id":"bg","type":"fill_rect","x":0,"y":0,"width":"$canvas.width","height":"$canvas.height","color":"@brand.colors.background","opacity":1},
    {"id":"bg_glow","type":"radial_gradient","cx":"$canvas.width*0.5","cy":"$canvas.height*0.4","radius":500,"color_start":"@brand.colors.primary","opacity_start":0.07,"color_end":"@brand.colors.primary","opacity_end":0,"opacity":1},
    {"id":"vignette","type":"vignette","inner_radius":200,"outer_radius":900,"color":"#000000","strength":0.5,"opacity":0},
    {"id":"top_rule","type":"double_rule","x1":90,"x2":"$canvas.width-90","y":108,"gap":12,"stroke_width":1.5,"color":"@brand.colors.primary","opacity":0},
    {"id":"topic_tag","type":"tag","content_ref":"@data.topic","font":"@brand.fonts.grotesk","size":22,"weight":600,"letter_spacing":4,"color":"@brand.colors.primary","bg_opacity":0.1,"border":true,"border_opacity":0.4,"padding_h":36,"padding_v":16,"x":"$canvas.width*0.5","y":"$canvas.height*0.185","align":"center","opacity":0},
    {"id":"open_quote","type":"text","content":"\u201C","font":"@brand.fonts.serif","size":200,"color":"@brand.colors.primary","color_opacity":0.13,"x":80,"y":440,"align":"left","baseline":"alphabetic","opacity":0},
    {"id":"quote_text","type":"text_block","content_ref":"@data.quote_text","max_width":"$canvas.width-180","font":"@brand.fonts.serif","size":70,"weight":700,"color":"@brand.colors.text","line_height":90,"x":"$canvas.width*0.5","y":"$canvas.height*0.36","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"dots","type":"text","content":"\u00B7 \u00B7 \u00B7","font":"@brand.fonts.sans","size":26,"color":"@brand.colors.primary","x":"$canvas.width*0.5","y":"$canvas.height*0.71","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"author_name","type":"text","content_ref":"@data.author_name","font":"@brand.fonts.serif","size":36,"weight":700,"color":"@brand.colors.text","x":"$canvas.width*0.5","y":"$canvas.height*0.77","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"divider","type":"divider_ornament","x1":108,"x2":"$canvas.width-108","y":"$canvas.height*0.83","gap":10,"stroke_width":1,"color":"@brand.colors.primary","centre":"diamond","centre_size":10,"inner_gap":24,"opacity":0},
    {"id":"source_tag","type":"source_tag","content_ref":"@data.source","prefix":"","font":"@brand.fonts.mono","size":18,"letter_spacing":1,"color":"@brand.colors.primary","bg_opacity":0.08,"border_opacity":0.2,"padding_h":28,"padding_v":12,"x":"$canvas.width*0.5","y":"$canvas.height*0.893","align":"center","opacity":0},
    {"id":"brand_logo","type":"brand_watermark","font":"@brand.fonts.mono","size":17,"letter_spacing":5,"color":"@brand.colors.muted","color_opacity":0.35,"x":"$canvas.width*0.5","y":"$canvas.height*0.94","align":"center","baseline":"alphabetic","opacity":0}
  ],
  "animations": [
    {"layer_id":"vignette","property":"opacity","from_value":0,"to_value":1,"start_frame":0,"end_frame":30,"easing":"ease_out"},
    {"layer_id":"top_rule","property":"opacity","from_value":0,"to_value":0.5,"start_frame":5,"end_frame":35,"easing":"ease_out"},
    {"layer_id":"top_rule","property":"scale_x","from_value":0,"to_value":1,"start_frame":5,"end_frame":38,"easing":"ease_out"},
    {"layer_id":"topic_tag","property":"opacity","from_value":0,"to_value":1,"start_frame":18,"end_frame":50,"easing":"ease_out"},
    {"layer_id":"topic_tag","property":"y","from_value":16,"to_value":0,"start_frame":18,"end_frame":50,"easing":"ease_out"},
    {"layer_id":"open_quote","property":"opacity","from_value":0,"to_value":1,"start_frame":35,"end_frame":65,"easing":"ease_out"},
    {"layer_id":"quote_text","property":"opacity","from_value":0,"to_value":1,"start_frame":45,"end_frame":92,"easing":"ease_out"},
    {"layer_id":"quote_text","property":"y","from_value":24,"to_value":0,"start_frame":45,"end_frame":92,"easing":"ease_out"},
    {"layer_id":"dots","property":"opacity","from_value":0,"to_value":1,"start_frame":105,"end_frame":130,"easing":"ease_out"},
    {"layer_id":"author_name","property":"opacity","from_value":0,"to_value":1,"start_frame":118,"end_frame":148,"easing":"ease_out"},
    {"layer_id":"author_name","property":"y","from_value":16,"to_value":0,"start_frame":118,"end_frame":148,"easing":"ease_out"},
    {"layer_id":"divider","property":"opacity","from_value":0,"to_value":1,"start_frame":155,"end_frame":178,"easing":"ease_out"},
    {"layer_id":"divider","property":"scale_x","from_value":0,"to_value":1,"start_frame":155,"end_frame":180,"easing":"ease_out"},
    {"layer_id":"source_tag","property":"opacity","from_value":0,"to_value":1,"start_frame":182,"end_frame":205,"easing":"ease_out"},
    {"layer_id":"brand_logo","property":"opacity","from_value":0,"to_value":1,"start_frame":200,"end_frame":225,"easing":"ease_out"}
  ]
}
