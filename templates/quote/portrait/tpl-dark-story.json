{
  "meta": {
    "template_id": "quote-portrait-story-v1",
    "intent": "quote",
    "mode": "portrait",
    "size": "story",
    "version": "1.0",
    "total_frames": 270,
    "fps": 30,
    "best_frame": 218
  },
  "canvas": {
    "ratio": "9:16",
    "width": 1080,
    "height": 1920,
    "background": "#0A0A0C"
  },
  "brand": {
    "logo": "MINDFUL·CO",
    "colors": {
      "primary": "#C8A96E",
      "background": "#0A0A0C",
      "text": "#F5F2EB",
      "muted": "#7A7468",
      "surface": "#111114"
    },
    "fonts": {
      "display": "Bebas Neue",
      "serif": "Playfair Display",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk"
    }
  },
  "data": {
    "quote_text": "Stay hungry. Stay foolish.",
    "author_name": "Steve Jobs",
    "author_image": "https://picsum.photos/id/1/400/400",
    "source": "Stanford Commencement, 2005"
  },
  "layers": [
    {
      "id": "bg",
      "type": "fill_rect",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "color": "@brand.colors.background",
      "opacity": 1
    },
    {
      "id": "bg_gradient",
      "type": "linear_gradient",
      "x1": 0,
      "y1": 0,
      "x2": 0,
      "y2": "$canvas.height",
      "color_start": "#1a1008",
      "opacity_start": 0.9,
      "color_end": "#0A0A0C",
      "opacity_end": 1,
      "opacity": 1
    },
    {
      "id": "vignette",
      "type": "vignette",
      "inner_radius": 200,
      "outer_radius": 900,
      "color": "#000000",
      "strength": 0.6,
      "opacity": 0
    },
    {
      "id": "rule_l",
      "type": "line",
      "x1": 90,
      "y1": 108,
      "x2": "$canvas.width*0.43",
      "y2": 108,
      "color": "@brand.colors.primary",
      "stroke_width": 1.5,
      "origin": "center",
      "opacity": 0
    },
    {
      "id": "diamond",
      "type": "diamond",
      "cx": "$canvas.width*0.5",
      "cy": 108,
      "size": 12,
      "color": "@brand.colors.primary",
      "opacity": 0
    },
    {
      "id": "rule_r",
      "type": "line",
      "x1": "$canvas.width*0.57",
      "y1": 108,
      "x2": "$canvas.width-90",
      "y2": 108,
      "color": "@brand.colors.primary",
      "stroke_width": 1.5,
      "origin": "center",
      "opacity": 0
    },
    {
      "id": "open_quote",
      "type": "text",
      "content": "“",
      "font": "@brand.fonts.serif",
      "size": 280,
      "color": "@brand.colors.primary",
      "color_opacity": 0.15,
      "x": 80,
      "y": 600,
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "quote_text",
      "type": "text_block",
      "content_ref": "@data.quote_text",
      "max_width": "$canvas.width-180",
      "font": "@brand.fonts.serif",
      "size": 88,
      "weight": 700,
      "color": "@brand.colors.text",
      "line_height": 110,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.38",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "dots",
      "type": "text",
      "content": "· · ·",
      "font": "@brand.fonts.sans",
      "size": 32,
      "color": "@brand.colors.primary",
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.635",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "author_img",
      "type": "image_circle",
      "src": "@data.author_image",
      "cx": "$canvas.width*0.5",
      "cy": "$canvas.height*0.735",
      "radius": 100,
      "stroke_color": "@brand.colors.primary",
      "stroke_width": 3,
      "stroke_opacity": 0.7,
      "opacity": 0
    },
    {
      "id": "author_name",
      "type": "text",
      "content_ref": "@data.author_name",
      "font": "@brand.fonts.serif",
      "size": 42,
      "weight": 700,
      "color": "@brand.colors.text",
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.818",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "source_tag",
      "type": "source_tag",
      "content_ref": "@data.source",
      "prefix": "",
      "font": "@brand.fonts.mono",
      "size": 20,
      "letter_spacing": 1,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.08,
      "border_opacity": 0.2,
      "padding_h": 32,
      "padding_v": 14,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.872",
      "align": "center",
      "opacity": 0
    },
    {
      "id": "brand_logo",
      "type": "brand_watermark",
      "font": "@brand.fonts.mono",
      "size": 18,
      "letter_spacing": 5,
      "color": "@brand.colors.muted",
      "color_opacity": 0.35,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.928",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    }
  ],
  "animations": [
    {
      "layer_id": "vignette",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 0,
      "end_frame": 30,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule_l",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.5,
      "start_frame": 8,
      "end_frame": 38,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule_l",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 8,
      "end_frame": 40,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule_r",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.5,
      "start_frame": 8,
      "end_frame": 38,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule_r",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 8,
      "end_frame": 40,
      "easing": "ease_out"
    },
    {
      "layer_id": "diamond",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.9,
      "start_frame": 10,
      "end_frame": 38,
      "easing": "elastic_out"
    },
    {
      "layer_id": "diamond",
      "property": "scale",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 10,
      "end_frame": 40,
      "easing": "elastic_out"
    },
    {
      "layer_id": "open_quote",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 22,
      "end_frame": 55,
      "easing": "ease_out"
    },
    {
      "layer_id": "quote_text",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 35,
      "end_frame": 80,
      "easing": "ease_out"
    },
    {
      "layer_id": "quote_text",
      "property": "y",
      "from_value": 24,
      "to_value": 0,
      "start_frame": 35,
      "end_frame": 80,
      "easing": "ease_out"
    },
    {
      "layer_id": "dots",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 90,
      "end_frame": 118,
      "easing": "ease_out"
    },
    {
      "layer_id": "author_img",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 105,
      "end_frame": 140,
      "easing": "ease_out"
    },
    {
      "layer_id": "author_img",
      "property": "scale",
      "from_value": 0.7,
      "to_value": 1,
      "start_frame": 105,
      "end_frame": 142,
      "easing": "elastic_out"
    },
    {
      "layer_id": "author_name",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 135,
      "end_frame": 162,
      "easing": "ease_out"
    },
    {
      "layer_id": "author_name",
      "property": "y",
      "from_value": 16,
      "to_value": 0,
      "start_frame": 135,
      "end_frame": 162,
      "easing": "ease_out"
    },
    {
      "layer_id": "source_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 170,
      "end_frame": 195,
      "easing": "ease_out"
    },
    {
      "layer_id": "brand_logo",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 190,
      "end_frame": 215,
      "easing": "ease_out"
    }
  ],
  "playback": {}
}