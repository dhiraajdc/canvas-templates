{
  "meta": { "template_id": "dyk-data-story-dark-grid-v1", "intent": "did_you_know", "mode": "stat", "style": "dark_grid", "version": "1.0", "total_frames": 300, "fps": 60 },
  "canvas": { "width": 1080, "height": 1350, "background": "#08080A" },
  "brand": { "logo": "INSIGHT·DAILY", "colors": { "primary": "#6B3CF7", "background": "#08080A", "text": "#F5F2EB", "muted": "#888888", "surface": "#111520" }, "fonts": { "display": "Bebas Neue", "serif": "Playfair Display", "sans": "DM Sans", "mono": "DM Mono", "grotesk": "Space Grotesk" } },
  "data": { "stat_value": "73", "stat_unit": "%", "stat_desc": "of remote workers report higher productivity at home", "source": "Stanford Research 2024" },
  "layers": [
    { "id": "bg_glow", "type": "radial_gradient", "cx": "$canvas.width*0.5", "cy": "$canvas.height*0.35", "radius": 560, "color_start": "@brand.colors.primary", "opacity_start": 0.14, "color_end": "@brand.colors.primary", "opacity_end": 0, "opacity": 1 },
    { "id": "dot_grid", "type": "dot_grid", "spacing": 72, "dot_radius": 2, "color": "@brand.colors.primary", "opacity": 0.07 },
    { "id": "left_rule", "type": "rectangle", "x": 70, "y": "$canvas.height*0.5-500", "width": 4, "height": 1000, "color": "@brand.colors.primary", "opacity": 0.55 },
    { "id": "eyebrow_text", "type": "text", "content": "// DID YOU KNOW", "font": "@brand.fonts.mono", "size": 20, "weight": 400, "letter_spacing": 4, "color": "@brand.colors.primary", "x": 108, "y": 118, "align": "left", "baseline": "alphabetic", "opacity": 0 },
    { "id": "eyebrow_rule", "type": "line", "x1": 108, "y1": 130, "x2": "$canvas.width-108", "y2": 130, "color": "@brand.colors.primary", "stroke_width": 1, "opacity": 0, "origin": "left" },
    { "id": "ghost_number", "type": "text", "content_ref": "@data.stat_value", "font": "@brand.fonts.display", "size": 700, "color": "@brand.colors.primary", "x": "$canvas.width*0.5+40", "y": "$canvas.height*0.5+60", "align": "center", "baseline": "middle", "opacity": 0 },
    { "id": "stat", "type": "text_countup", "content_ref": "@data.stat_value", "unit_ref": "@data.stat_unit", "font": "@brand.fonts.display", "size": 340, "color": "@brand.colors.text", "unit_color": "@brand.colors.primary", "unit_size": 72, "unit_font": "@brand.fonts.grotesk", "unit_weight": 500, "unit_offset_x": 30, "unit_offset_y": 270, "x": "$canvas.width*0.5", "y": "$canvas.height*0.47", "align": "center", "baseline": "alphabetic", "opacity": 0 },
    { "id": "stat_desc", "type": "text_multiline", "content_ref": "@data.stat_desc", "wrap_at": 38, "font": "@brand.fonts.sans", "size": 36, "weight": 300, "color": "@brand.colors.text", "color_opacity": 0.5, "x": "$canvas.width*0.5", "y": "$canvas.height*0.575", "align": "center", "baseline": "alphabetic", "line_height": 52, "opacity": 0 },
    { "id": "divider", "type": "line", "x1": 108, "y1": "$canvas.height*0.648", "x2": "$canvas.width-108", "y2": "$canvas.height*0.648", "color": "@brand.colors.primary", "stroke_width": 1, "opacity": 0, "origin": "left" },
    { "id": "source_tag", "type": "source_tag", "content_ref": "@data.source", "prefix": "SOURCE: ", "font": "@brand.fonts.mono", "size": 20, "letter_spacing": 1, "color": "@brand.colors.primary", "bg_opacity": 0.1, "border_opacity": 0.2, "padding_h": 36, "padding_v": 14, "x": "$canvas.width*0.5", "y": "$canvas.height*0.692", "align": "center", "opacity": 0 },
    { "id": "brand_logo", "type": "brand_watermark", "font": "@brand.fonts.mono", "size": 18, "letter_spacing": 4, "color": "@brand.colors.text", "color_opacity": 0.28, "x": "$canvas.width*0.5", "y": "$canvas.height-96", "align": "center", "baseline": "alphabetic", "opacity": 0 }
  ],
  "animations": [
    { "layer_id": "left_rule", "property": "scale_y", "from_value": 0, "to_value": 1, "start_frame": 0, "end_frame": 40, "easing": "ease_out" },
    { "layer_id": "eyebrow_text", "property": "opacity", "from_value": 0, "to_value": 1, "start_frame": 5, "end_frame": 35, "easing": "ease_out" },
    { "layer_id": "eyebrow_text", "property": "y", "from_value": 20, "to_value": 0, "start_frame": 5, "end_frame": 35, "easing": "ease_out" },
    { "layer_id": "eyebrow_rule", "property": "opacity", "from_value": 0, "to_value": 0.3, "start_frame": 5, "end_frame": 45, "easing": "ease_out" },
    { "layer_id": "eyebrow_rule", "property": "scale_x", "from_value": 0, "to_value": 1, "start_frame": 5, "end_frame": 45, "easing": "ease_out" },
    { "layer_id": "ghost_number", "property": "opacity", "from_value": 0, "to_value": 0.04, "start_frame": 10, "end_frame": 65, "easing": "ease_out" },
    { "layer_id": "stat", "property": "opacity", "from_value": 0, "to_value": 1, "start_frame": 18, "end_frame": 63, "easing": "ease_out" },
    { "layer_id": "stat", "property": "count_progress", "from_value": 0, "to_value": 1, "start_frame": 18, "end_frame": 108, "easing": "ease_out" },
    { "layer_id": "stat_desc", "property": "opacity", "from_value": 0, "to_value": 1, "start_frame": 90, "end_frame": 130, "easing": "ease_out" },
    { "layer_id": "stat_desc", "property": "y", "from_value": 20, "to_value": 0, "start_frame": 90, "end_frame": 130, "easing": "ease_out" },
    { "layer_id": "divider", "property": "opacity", "from_value": 0, "to_value": 0.2, "start_frame": 115, "end_frame": 145, "easing": "ease_out" },
    { "layer_id": "divider", "property": "scale_x", "from_value": 0, "to_value": 1, "start_frame": 115, "end_frame": 145, "easing": "ease_out" },
    { "layer_id": "source_tag", "property": "opacity", "from_value": 0, "to_value": 1, "start_frame": 125, "end_frame": 155, "easing": "ease_out" },
    { "layer_id": "source_tag", "property": "y", "from_value": 20, "to_value": 0, "start_frame": 125, "end_frame": 155, "easing": "ease_out" },
    { "layer_id": "brand_logo", "property": "opacity", "from_value": 0, "to_value": 1, "start_frame": 165, "end_frame": 200, "easing": "ease_out" }
  ]
}