{
  "meta": {"template_id":"dyk-timeframe-v1","intent":"did_you_know","mode":"timeframe","style":"neon_timeframe","version":"3.1","total_frames":270,"fps":30},
  "canvas": {"ratio":"4:5","background":"#08080A"},
  "brand": {
    "logo":"INSIGHT·HQ",
    "colors":{"primary":"#6B3CF7","background":"#08080A","text":"#F5F2EB","muted":"#888888","surface":"#111520"},
    "fonts":{"display":"Bebas Neue","serif":"Playfair Display","sans":"DM Sans","mono":"DM Mono","grotesk":"Space Grotesk"}
  },
  "data": {"time_value":"60","time_unit":"seconds","event_value":"500","event_unit":"hours","event_desc":"of video are uploaded to YouTube","source":"YouTube 2024"},
  "layers": [
    {"id":"bg","type":"fill_rect","x":0,"y":0,"width":"$canvas.width","height":"$canvas.height","color":"@brand.colors.background","opacity":1},
    {"id":"bg_glow","type":"radial_gradient","cx":"$canvas.width*0.5","cy":"$canvas.height*0.38","radius":480,"color_start":"@brand.colors.primary","opacity_start":0.12,"color_end":"@brand.colors.primary","opacity_end":0,"opacity":1},
    {"id":"vignette","type":"vignette","inner_radius":200,"outer_radius":900,"color":"#000000","strength":0.5,"opacity":0},
    {"id":"eyebrow","type":"text","content":"EVERY","font":"@brand.fonts.grotesk","size":22,"weight":300,"letter_spacing":12,"color":"@brand.colors.primary","x":"$canvas.width*0.5","y":"$canvas.height*0.17","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"time_value","type":"number_display","value_ref":"@data.time_value","count_up":true,"font":"@brand.fonts.display","size":220,"color":"@brand.colors.text","unit_text":"@data.time_unit","unit_size":40,"unit_font":"@brand.fonts.grotesk","unit_weight":300,"unit_color":"@brand.colors.muted","unit_offset_x":12,"unit_offset_y":178,"x":"$canvas.width*0.5","y":"$canvas.height*0.4","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"dash","type":"dashed_line","x1":"$canvas.width*0.25","y1":"$canvas.height*0.497","x2":"$canvas.width*0.75","y2":"$canvas.height*0.497","color":"@brand.colors.primary","stroke_width":1,"dash":[4,8],"opacity":0},
    {"id":"event_value","type":"number_display","value_ref":"@data.event_value","count_up":true,"font":"@brand.fonts.display","size":180,"color":"@brand.colors.primary","unit_text":"@data.event_unit","unit_size":36,"unit_font":"@brand.fonts.grotesk","unit_weight":300,"unit_color":"@brand.colors.muted","unit_offset_x":12,"unit_offset_y":145,"x":"$canvas.width*0.5","y":"$canvas.height*0.63","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"event_desc","type":"text_block","content_ref":"@data.event_desc","max_width":"$canvas.width-200","font":"@brand.fonts.sans","size":32,"weight":300,"color":"@brand.colors.text","color_opacity":0.55,"line_height":48,"x":"$canvas.width*0.5","y":"$canvas.height*0.735","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"bottom_rule","type":"line","x1":90,"y1":"$canvas.height*0.84","x2":"$canvas.width-90","y2":"$canvas.height*0.84","color":"@brand.colors.primary","stroke_width":1,"origin":"center","opacity":0},
    {"id":"source_tag","type":"source_tag","content_ref":"@data.source","prefix":"SOURCE: ","font":"@brand.fonts.mono","size":18,"letter_spacing":1,"color":"@brand.colors.primary","bg_opacity":0.08,"border_opacity":0.2,"padding_h":28,"padding_v":12,"x":"$canvas.width*0.5","y":"$canvas.height*0.875","align":"center","opacity":0},
    {"id":"brand_logo","type":"brand_watermark","font":"@brand.fonts.mono","size":17,"letter_spacing":5,"color":"@brand.colors.muted","color_opacity":0.35,"x":"$canvas.width*0.5","y":"$canvas.height*0.94","align":"center","baseline":"alphabetic","opacity":0}
  ],
  "animations": [
    {"layer_id":"vignette","property":"opacity","from_value":0,"to_value":1,"start_frame":0,"end_frame":30,"easing":"ease_out"},
    {"layer_id":"eyebrow","property":"opacity","from_value":0,"to_value":1,"start_frame":8,"end_frame":35,"easing":"ease_out"},
    {"layer_id":"eyebrow","property":"y","from_value":14,"to_value":0,"start_frame":8,"end_frame":35,"easing":"ease_out"},
    {"layer_id":"time_value","property":"opacity","from_value":0,"to_value":1,"start_frame":20,"end_frame":55,"easing":"ease_out"},
    {"layer_id":"time_value","property":"count_progress","from_value":0,"to_value":1,"start_frame":20,"end_frame":80,"easing":"ease_out"},
    {"layer_id":"dash","property":"opacity","from_value":0,"to_value":1,"start_frame":85,"end_frame":108,"easing":"ease_out"},
    {"layer_id":"event_value","property":"opacity","from_value":0,"to_value":1,"start_frame":95,"end_frame":128,"easing":"ease_out"},
    {"layer_id":"event_value","property":"count_progress","from_value":0,"to_value":1,"start_frame":95,"end_frame":150,"easing":"ease_out"},
    {"layer_id":"event_desc","property":"opacity","from_value":0,"to_value":1,"start_frame":158,"end_frame":188,"easing":"ease_out"},
    {"layer_id":"event_desc","property":"y","from_value":18,"to_value":0,"start_frame":158,"end_frame":188,"easing":"ease_out"},
    {"layer_id":"bottom_rule","property":"opacity","from_value":0,"to_value":0.35,"start_frame":198,"end_frame":220,"easing":"ease_out"},
    {"layer_id":"bottom_rule","property":"scale_x","from_value":0,"to_value":1,"start_frame":198,"end_frame":222,"easing":"ease_out"},
    {"layer_id":"source_tag","property":"opacity","from_value":0,"to_value":1,"start_frame":212,"end_frame":235,"easing":"ease_out"},
    {"layer_id":"brand_logo","property":"opacity","from_value":0,"to_value":1,"start_frame":228,"end_frame":250,"easing":"ease_out"}
  ]
}
