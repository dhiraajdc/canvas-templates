{
  "meta": {"template_id":"dyk-ratio-v1","intent":"did_you_know","mode":"ratio","style":"dark_ratio","version":"3.1","total_frames":270,"fps":30},
  "canvas": {"ratio":"4:5","background":"#08080A"},
  "brand": {
    "logo":"INSIGHT·HQ",
    "colors":{"primary":"#6B3CF7","background":"#08080A","text":"#F5F2EB","muted":"#888888","surface":"#111520"},
    "fonts":{"display":"Bebas Neue","serif":"Playfair Display","sans":"DM Sans","mono":"DM Mono","grotesk":"Space Grotesk"}
  },
  "data": {"ratio_numerator":"1","ratio_denominator":"5","ratio_desc":"adults experience a mental health condition each year","source":"WHO 2024"},
  "layers": [
    {"id":"bg","type":"fill_rect","x":0,"y":0,"width":"$canvas.width","height":"$canvas.height","color":"@brand.colors.background","opacity":1},
    {"id":"bg_glow","type":"radial_gradient","cx":"$canvas.width*0.5","cy":"$canvas.height*0.42","radius":500,"color_start":"@brand.colors.primary","opacity_start":0.1,"color_end":"@brand.colors.primary","opacity_end":0,"opacity":1},
    {"id":"vignette","type":"vignette","inner_radius":200,"outer_radius":900,"color":"#000000","strength":0.5,"opacity":0},
    {"id":"eyebrow","type":"text","content":"DID YOU KNOW","font":"@brand.fonts.grotesk","size":20,"weight":300,"letter_spacing":8,"color":"@brand.colors.muted","x":"$canvas.width*0.5","y":148,"align":"center","baseline":"alphabetic","opacity":0},
    {"id":"num_a","type":"text","content_ref":"@data.ratio_numerator","font":"@brand.fonts.display","size":280,"color":"@brand.colors.text","x":"$canvas.width*0.28","y":"$canvas.height*0.52","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"connector","type":"text","content":"IN","font":"@brand.fonts.grotesk","size":36,"weight":300,"letter_spacing":8,"color":"@brand.colors.muted","x":"$canvas.width*0.5","y":"$canvas.height*0.415","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"line_top","type":"line","x1":"$canvas.width*0.42","y1":"$canvas.height*0.388","x2":"$canvas.width*0.58","y2":"$canvas.height*0.388","color":"@brand.colors.primary","stroke_width":1,"origin":"center","opacity":0},
    {"id":"line_bot","type":"line","x1":"$canvas.width*0.42","y1":"$canvas.height*0.428","x2":"$canvas.width*0.58","y2":"$canvas.height*0.428","color":"@brand.colors.primary","stroke_width":1,"origin":"center","opacity":0},
    {"id":"num_b","type":"text","content_ref":"@data.ratio_denominator","font":"@brand.fonts.display","size":280,"color":"@brand.colors.primary","color_opacity":0.32,"x":"$canvas.width*0.72","y":"$canvas.height*0.52","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"ratio_desc","type":"text_block","content_ref":"@data.ratio_desc","max_width":"$canvas.width-200","font":"@brand.fonts.sans","size":34,"weight":300,"color":"@brand.colors.text","color_opacity":0.65,"line_height":50,"x":"$canvas.width*0.5","y":"$canvas.height*0.64","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"divider","type":"double_rule","x1":90,"x2":"$canvas.width-90","y":"$canvas.height*0.78","gap":10,"stroke_width":1,"color":"@brand.colors.primary","opacity":0},
    {"id":"source_tag","type":"source_tag","content_ref":"@data.source","prefix":"SOURCE: ","font":"@brand.fonts.mono","size":18,"letter_spacing":1,"color":"@brand.colors.primary","bg_opacity":0.08,"border_opacity":0.2,"padding_h":28,"padding_v":12,"x":"$canvas.width*0.5","y":"$canvas.height*0.875","align":"center","opacity":0},
    {"id":"brand_logo","type":"brand_watermark","font":"@brand.fonts.mono","size":17,"letter_spacing":5,"color":"@brand.colors.muted","color_opacity":0.35,"x":"$canvas.width*0.5","y":"$canvas.height*0.94","align":"center","baseline":"alphabetic","opacity":0}
  ],
  "animations": [
    {"layer_id":"vignette","property":"opacity","from_value":0,"to_value":1,"start_frame":0,"end_frame":30,"easing":"ease_out"},
    {"layer_id":"eyebrow","property":"opacity","from_value":0,"to_value":1,"start_frame":10,"end_frame":38,"easing":"ease_out"},
    {"layer_id":"num_a","property":"opacity","from_value":0,"to_value":1,"start_frame":25,"end_frame":62,"easing":"ease_out"},
    {"layer_id":"num_a","property":"y","from_value":30,"to_value":0,"start_frame":25,"end_frame":62,"easing":"ease_out"},
    {"layer_id":"line_top","property":"opacity","from_value":0,"to_value":1,"start_frame":40,"end_frame":65,"easing":"ease_out"},
    {"layer_id":"line_top","property":"scale_x","from_value":0,"to_value":1,"start_frame":40,"end_frame":68,"easing":"ease_out"},
    {"layer_id":"line_bot","property":"opacity","from_value":0,"to_value":1,"start_frame":40,"end_frame":65,"easing":"ease_out"},
    {"layer_id":"line_bot","property":"scale_x","from_value":0,"to_value":1,"start_frame":40,"end_frame":68,"easing":"ease_out"},
    {"layer_id":"connector","property":"opacity","from_value":0,"to_value":1,"start_frame":42,"end_frame":68,"easing":"ease_out"},
    {"layer_id":"num_b","property":"opacity","from_value":0,"to_value":1,"start_frame":55,"end_frame":92,"easing":"ease_out"},
    {"layer_id":"num_b","property":"y","from_value":30,"to_value":0,"start_frame":55,"end_frame":92,"easing":"ease_out"},
    {"layer_id":"ratio_desc","property":"opacity","from_value":0,"to_value":1,"start_frame":105,"end_frame":140,"easing":"ease_out"},
    {"layer_id":"ratio_desc","property":"y","from_value":20,"to_value":0,"start_frame":105,"end_frame":140,"easing":"ease_out"},
    {"layer_id":"divider","property":"opacity","from_value":0,"to_value":0.4,"start_frame":152,"end_frame":175,"easing":"ease_out"},
    {"layer_id":"divider","property":"scale_x","from_value":0,"to_value":1,"start_frame":152,"end_frame":178,"easing":"ease_out"},
    {"layer_id":"source_tag","property":"opacity","from_value":0,"to_value":1,"start_frame":185,"end_frame":210,"easing":"ease_out"},
    {"layer_id":"brand_logo","property":"opacity","from_value":0,"to_value":1,"start_frame":205,"end_frame":228,"easing":"ease_out"}
  ]
}
