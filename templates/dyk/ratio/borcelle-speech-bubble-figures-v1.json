{
  "meta": {
    "template_id": "borcelle-speech-bubble-figures-v1",
    "intent": "did_you_know",
    "mode": "ratio",
    "style": "playful_speech_bubble_people",
    "version": "3.1",
    "total_frames": 300,
    "fps": 30,
    "best_frame": 90
  },
  "dynamic_logic": {
    "description": "Declarative per-layer logic. The renderer evaluates these before drawing each layer.",
    "visible_if": "Object {left, op, right}. If it evaluates false, the layer is skipped entirely (not drawn). left/right may be literals or @data.* / @brand.* refs; both sides are coerced to Number for comparison ops.",
    "conditional_fields": "Any field whose value is an object of shape {if:{left,op,right}, then:<value>, else:<value>} is collapsed to `then` when the condition holds, otherwise `else`. Used here on `color`.",
    "operators": [
      "<=",
      "<",
      ">=",
      ">",
      "==",
      "!="
    ],
    "rules": {
      "figure_visible": "slot_index <= ratio_denominator   -> figure is shown",
      "figure_highlighted": "slot_index <= ratio_numerator   -> figure uses surface (dark) colour, else muted (purple)"
    }
  },
  "canvas": {
    "ratio": "4:5",
    "background": "@brand.colors.background",
    "width": 1080,
    "height": 1350
  },
  "brand": {
    "logo": "BORCELLE·CO",
    "colors": {
      "primary": "#F4663B",
      "background": "#EBE7F3",
      "text": "#1B0E47",
      "muted": "#7B2FBF",
      "surface": "#22104A"
    },
    "fonts": {
      "display": "Bebas Neue",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk",
      "serif": "Playfair Display"
    }
  },
  "data": {
    "ratio_numerator": "1",
    "ratio_denominator": "5",
    "ratio_desc": "adults experience a mental health condition each year",
    "source": "WHO 2024"
  },
