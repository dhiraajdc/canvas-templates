{
  "meta": {
    "template_id": "news-headline-v1",
    "intent": "news",
    "mode": "headline",
    "style": "light_editorial",
    "version": "1.0",
    "total_frames": 270,
    "fps": 30
  },
  "canvas": {
    "ratio": "4:5",
    "background": "#F5F4F0"
  },
  "brand": {
    "logo": "THE\u00b7BRIEF",
    "colors": {
      "primary": "#0F172A",
      "background": "#F5F4F0",
      "text": "#0D0D0F",
      "muted": "#6B7280",
      "surface": "#FFFFFF",
      "accent": "#0F172A"
    },
    "fonts": {
      "display": "Bebas Neue",
      "serif": "Playfair Display",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk"
    }
  },
  "data": {
    "headline": "India launches its largest solar power plant in Rajasthan desert",
    "summary": "The 2,400 MW facility is now operational, powering over 1.5 million homes and marking a major milestone in India's renewable energy ambitions.",
    "category": "Energy",
    "source_name": "The Hindu",
    "published": "30 May 2026",
    "image_url": "https://picsum.photos/id/10/1080/1350",
    "article_url": "https://thehindu.com"
  },
  "layers": [
    {
      "id": "bg",
      "type": "fill_rect",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "color": "@brand.colors.background",
      "opacity": 1
    },
    {
      "id": "news_image",
      "type": "image_fill",
      "src": "@data.image_url",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height*0.52",
      "fit": "cover",
      "opacity": 0
    },
    {
      "id": "image_gradient",
      "type": "linear_gradient",
      "x1": 0,
      "y1": "$canvas.height*0.32",
      "x2": 0,
      "y2": "$canvas.height*0.54",
      "color_start": "#F5F4F0",
      "opacity_start": 0,
      "color_end": "#F5F4F0",
      "opacity_end": 1,
      "opacity": 1
    },
    {
      "id": "image_top_fade",
      "type": "linear_gradient",
      "x1": 0,
      "y1": 0,
      "x2": 0,
      "y2": 80,
      "color_start": "#0D0D0F",
      "opacity_start": 0.2,
      "color_end": "#0D0D0F",
      "opacity_end": 0,
      "opacity": 1
    },
    {
      "id": "category_tag",
      "type": "tag",
      "content_ref": "@data.category",
      "font": "@brand.fonts.grotesk",
      "size": 20,
      "weight": 600,
      "letter_spacing": 3,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.07,
      "border": true,
      "border_opacity": 0.2,
      "padding_h": 24,
      "padding_v": 12,
      "x": 80,
      "y": "$canvas.height*0.565",
      "align": "left",
      "opacity": 0
    },
    {
      "id": "headline",
      "type": "text_block",
      "content_ref": "@data.headline",
      "max_width": "$canvas.width-160",
      "font": "@brand.fonts.serif",
      "size": 58,
      "weight": 700,
      "color": "@brand.colors.text",
      "line_height": 74,
      "x": 80,
      "y": "$canvas.height*0.618",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "divider",
      "type": "line",
      "x1": 80,
      "y1": "$canvas.height*0.782",
      "x2": "$canvas.width-80",
      "y2": "$canvas.height*0.782",
      "color": "@brand.colors.primary",
      "stroke_width": 1,
      "origin": "left",
      "opacity": 0
    },
    {
      "id": "summary",
      "type": "text_block",
      "content_ref": "@data.summary",
      "max_width": "$canvas.width-160",
      "font": "@brand.fonts.sans",
      "size": 28,
      "weight": 300,
      "color": "@brand.colors.muted",
      "line_height": 44,
      "x": 80,
      "y": "$canvas.height*0.808",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "bottom_rule",
      "type": "line",
      "x1": 80,
      "y1": "$canvas.height*0.918",
      "x2": "$canvas.width-80",
      "y2": "$canvas.height*0.918",
      "color": "@brand.colors.primary",
      "stroke_width": 1,
      "origin": "left",
      "opacity": 0
    },
    {
      "id": "source_name",
      "type": "text",
      "content_ref": "@data.source_name",
      "font": "@brand.fonts.grotesk",
      "size": 22,
      "weight": 600,
      "letter_spacing": 1,
      "color": "@brand.colors.text",
      "x": 80,
      "y": "$canvas.height*0.948",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "dot",
      "type": "text",
      "content": "\u00b7",
      "font": "@brand.fonts.sans",
      "size": 22,
      "weight": 400,
      "color": "@brand.colors.muted",
      "x": 260,
      "y": "$canvas.height*0.948",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "published",
      "type": "text",
      "content_ref": "@data.published",
      "font": "@brand.fonts.mono",
      "size": 20,
      "weight": 400,
      "color": "@brand.colors.muted",
      "x": 285,
      "y": "$canvas.height*0.948",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "brand_logo",
      "type": "brand_watermark",
      "font": "@brand.fonts.mono",
      "size": 17,
      "letter_spacing": 5,
      "color": "@brand.colors.muted",
      "color_opacity": 0.35,
      "x": "$canvas.width-80",
      "y": "$canvas.height*0.948",
      "align": "right",
      "baseline": "alphabetic",
      "opacity": 0
    }
  ],
  "animations": [
    {
      "layer_id": "news_image",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 0,
      "end_frame": 35,
      "easing": "ease_out"
    },
    {
      "layer_id": "category_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 30,
      "end_frame": 55,
      "easing": "ease_out"
    },
    {
      "layer_id": "category_tag",
      "property": "y",
      "from_value": 12,
      "to_value": 0,
      "start_frame": 30,
      "end_frame": 55,
      "easing": "ease_out"
    },
    {
      "layer_id": "headline",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 45,
      "end_frame": 90,
      "easing": "ease_out"
    },
    {
      "layer_id": "headline",
      "property": "y",
      "from_value": 20,
      "to_value": 0,
      "start_frame": 45,
      "end_frame": 90,
      "easing": "ease_out"
    },
    {
      "layer_id": "divider",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.25,
      "start_frame": 95,
      "end_frame": 118,
      "easing": "ease_out"
    },
    {
      "layer_id": "divider",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 95,
      "end_frame": 120,
      "easing": "ease_out"
    },
    {
      "layer_id": "summary",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 108,
      "end_frame": 148,
      "easing": "ease_out"
    },
    {
      "layer_id": "summary",
      "property": "y",
      "from_value": 14,
      "to_value": 0,
      "start_frame": 108,
      "end_frame": 148,
      "easing": "ease_out"
    },
    {
      "layer_id": "bottom_rule",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.2,
      "start_frame": 178,
      "end_frame": 198,
      "easing": "ease_out"
    },
    {
      "layer_id": "bottom_rule",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 178,
      "end_frame": 200,
      "easing": "ease_out"
    },
    {
      "layer_id": "source_name",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 188,
      "end_frame": 210,
      "easing": "ease_out"
    },
    {
      "layer_id": "dot",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 192,
      "end_frame": 212,
      "easing": "ease_out"
    },
    {
      "layer_id": "published",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 196,
      "end_frame": 215,
      "easing": "ease_out"
    },
    {
      "layer_id": "brand_logo",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 210,
      "end_frame": 232,
      "easing": "ease_out"
    }
  ]
}