{
  "meta": {"template_id":"tip-stat-tip-v1","intent":"tip","mode":"stat_tip","style":"stat_backed_tip","version":"3.1","total_frames":270,"fps":30},
  "canvas": {"ratio":"4:5","background":"#0A0A0C"},
  "brand": {
    "logo":"DAILY·TIP",
    "colors":{"primary":"#E8762A","background":"#0A0A0C","text":"#F5F2EB","muted":"#888888","surface":"#111520"},
    "fonts":{"display":"Bebas Neue","serif":"Playfair Display","sans":"DM Sans","mono":"DM Mono","grotesk":"Space Grotesk"}
  },
  "data": {"tip_headline":"Take more breaks while working","tip_body":"Short breaks restore focus and prevent decision fatigue throughout the day.","stat_value":"52","stat_unit":"min"},
  "layers": [
    {"id":"bg","type":"fill_rect","x":0,"y":0,"width":"$canvas.width","height":"$canvas.height","color":"@brand.colors.background","opacity":1},
    {"id":"bg_glow","type":"radial_gradient","cx":"$canvas.width*0.5","cy":"$canvas.height*0.65","radius":460,"color_start":"@brand.colors.primary","opacity_start":0.1,"color_end":"@brand.colors.primary","opacity_end":0,"opacity":1},
    {"id":"vignette","type":"vignette","inner_radius":200,"outer_radius":900,"color":"#000000","strength":0.45,"opacity":0},
    {"id":"tip_label","type":"tag","content":"TIP","font":"@brand.fonts.grotesk","size":18,"weight":700,"letter_spacing":6,"color":"@brand.colors.primary","bg_opacity":0.1,"border":true,"border_opacity":0.35,"padding_h":28,"padding_v":12,"x":"$canvas.width*0.5","y":"$canvas.height*0.12","align":"center","opacity":0},
    {"id":"headline","type":"text_block","content_ref":"@data.tip_headline","max_width":"$canvas.width-160","font":"@brand.fonts.serif","size":68,"weight":700,"color":"@brand.colors.text","line_height":86,"x":"$canvas.width*0.5","y":"$canvas.height*0.225","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"tip_body","type":"text_block","content_ref":"@data.tip_body","max_width":"$canvas.width-180","font":"@brand.fonts.sans","size":32,"weight":300,"color":"@brand.colors.text","color_opacity":0.6,"line_height":48,"x":"$canvas.width*0.5","y":"$canvas.height*0.42","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"stat_bg","type":"rectangle","x":140,"y":"$canvas.height*0.575","width":"$canvas.width-280","height":200,"color":"@brand.colors.primary","color_opacity":0.06,"stroke_color":"@brand.colors.primary","stroke_opacity":0.18,"stroke_width":1,"corner_radius":20,"opacity":0},
    {"id":"stat_number","type":"number_display","value_ref":"@data.stat_value","count_up":true,"font":"@brand.fonts.display","size":130,"color":"@brand.colors.primary","unit_text":"@data.stat_unit","unit_size":42,"unit_font":"@brand.fonts.grotesk","unit_weight":500,"unit_color":"@brand.colors.muted","unit_offset_x":12,"unit_offset_y":100,"x":"$canvas.width*0.5","y":"$canvas.height*0.695","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"stat_desc","type":"text","content":"optimal focus window","font":"@brand.fonts.grotesk","size":22,"weight":300,"color":"@brand.colors.muted","x":"$canvas.width*0.5","y":"$canvas.height*0.748","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"brand_logo","type":"brand_watermark","font":"@brand.fonts.mono","size":17,"letter_spacing":5,"color":"@brand.colors.muted","color_opacity":0.35,"x":"$canvas.width*0.5","y":"$canvas.height*0.94","align":"center","baseline":"alphabetic","opacity":0}
  ],
  "animations": [
    {"layer_id":"vignette","property":"opacity","from_value":0,"to_value":1,"start_frame":0,"end_frame":30,"easing":"ease_out"},
    {"layer_id":"tip_label","property":"opacity","from_value":0,"to_value":1,"start_frame":8,"end_frame":35,"easing":"ease_out"},
    {"layer_id":"headline","property":"opacity","from_value":0,"to_value":1,"start_frame":20,"end_frame":68,"easing":"ease_out"},
    {"layer_id":"headline","property":"y","from_value":22,"to_value":0,"start_frame":20,"end_frame":68,"easing":"ease_out"},
    {"layer_id":"tip_body","property":"opacity","from_value":0,"to_value":1,"start_frame":78,"end_frame":115,"easing":"ease_out"},
    {"layer_id":"tip_body","property":"y","from_value":16,"to_value":0,"start_frame":78,"end_frame":115,"easing":"ease_out"},
    {"layer_id":"stat_bg","property":"opacity","from_value":0,"to_value":1,"start_frame":128,"end_frame":155,"easing":"ease_out"},
    {"layer_id":"stat_number","property":"opacity","from_value":0,"to_value":1,"start_frame":138,"end_frame":165,"easing":"ease_out"},
    {"layer_id":"stat_number","property":"count_progress","from_value":0,"to_value":1,"start_frame":138,"end_frame":188,"easing":"ease_out"},
    {"layer_id":"stat_desc","property":"opacity","from_value":0,"to_value":1,"start_frame":178,"end_frame":205,"easing":"ease_out"},
    {"layer_id":"brand_logo","property":"opacity","from_value":0,"to_value":1,"start_frame":228,"end_frame":252,"easing":"ease_out"}
  ]
}
