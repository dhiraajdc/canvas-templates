    {"layer_id":"tick_3","property":"opacity","from_value":0,"to_value":1,"start_frame":180,"end_frame":202,"easing":"elastic_out"},
    {"layer_id":"tick_3","property":"scale","from_value":0,"to_value":1,"start_frame":180,"end_frame":204,"easing":"elastic_out"},
    {"layer_id":"item_3","property":"opacity","from_value":0,"to_value":1,"start_frame":188,"end_frame":215,"easing":"ease_out"},
