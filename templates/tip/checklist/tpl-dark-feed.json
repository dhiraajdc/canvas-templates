{
  "meta": {"template_id":"tip-checklist-v1","intent":"tip","mode":"checklist","style":"bold_checklist","version":"3.1","total_frames":270,"fps":30},
  "canvas": {"ratio":"4:5","background":"#0A0A0C"},
  "brand": {
    "logo":"DAILY·TIP",
    "colors":{"primary":"#E8762A","background":"#0A0A0C","text":"#F5F2EB","muted":"#888888","surface":"#111520"},
    "fonts":{"display":"Bebas Neue","serif":"Playfair Display","sans":"DM Sans","mono":"DM Mono","grotesk":"Space Grotesk"}
  },
  "data": {"tip_headline":"Before every important meeting","item_1":"Write down the one outcome you need","item_2":"Prepare your first question in advance","item_3":"Arrive 2 minutes early and breathe"},
  "layers": [
