    {"id":"headline","type":"text_block","content_ref":"@data.tip_headline","max_width":"$canvas.width-160","font":"@brand.fonts.serif","size":64,"weight":700,"color":"@brand.colors.text","line_height":80,"x":"$canvas.width*0.5","y":"$canvas.height*0.22","align":"center","baseline":"alphabetic","opacity":0},
    {"id":"divider","type":"divider_ornament","x1":108,"x2":"$canvas.width-108","y":"$canvas.height*0.42","gap":10,"stroke_width":1,"color":"@brand.colors.primary","centre":"diamond","centre_size":10,"inner_gap":24,"opacity":0},
    {"id":"tick_1","type":"rectangle","x":108,"y":"$canvas.height*0.498","width":32,"height":32,"color":"@brand.colors.primary","corner_radius":6,"opacity":0},
    {"id":"item_1","type":"text_block","content_ref":"@data.item_1","max_width":"$canvas.width-230","font":"@brand.fonts.sans","size":32,"weight":400,"color":"@brand.colors.text","line_height":46,"x":164,"y":"$canvas.height*0.52","align":"left","baseline":"alphabetic","opacity":0},
    {"id":"tick_2","type":"rectangle","x":108,"y":"$canvas.height*0.625","width":32,"height":32,"color":"@brand.colors.primary","corner_radius":6,"opacity":0},
    {"id":"item_2","type":"text_block","content_ref":"@data.item_2","max_width":"$canvas.width-230","font":"@brand.fonts.sans","size":32,"weight":400,"color":"@brand.colors.text","line_height":46,"x":164,"y":"$canvas.height*0.646","align":"left","baseline":"alphabetic","opacity":0},
    {"id":"tick_3","type":"rectangle","x":108,"y":"$canvas.height*0.752","width":32,"height":32,"color":"@brand.colors.primary","corner_radius":6,"opacity":0},
    {"id":"item_3","type":"text_block","content_ref":"@data.item_3","max_width":"$canvas.width-230","font":"@brand.fonts.sans","size":32,"weight":400,"color":"@brand.colors.text","line_height":46,"x":164,"y":"$canvas.height*0.773","align":"left","baseline":"alphabetic","opacity":0},
    {"id":"brand_logo","type":"brand_watermark","font":"@brand.fonts.mono","size":17,"letter_spacing":5,"color":"@brand.colors.muted","color_opacity":0.35,"x":"$canvas.width*0.5","y":"$canvas.height*0.94","align":"center","baseline":"alphabetic","opacity":0}
