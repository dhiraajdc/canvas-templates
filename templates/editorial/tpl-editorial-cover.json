{
  "meta": {
    "template_id": "editorial-cover-v1",
    "intent": "editorial",
    "mode": "cover",
    "style": "cinematic_cover",
    "version": "1.0",
    "total_frames": 240,
    "fps": 30
  },
  "canvas": {
    "width": 1080,
    "height": 1350,
    "background": "#08080A"
  },
  "brand": {
    "logo": "INSIGHT\u00b7DAILY",
    "colors": {
      "primary": "#6B3CF7",
      "background": "#08080A",
      "text": "#F5F2EB",
      "muted": "#888888",
      "surface": "#111520"
    },
    "fonts": {
      "display": "Bebas Neue",
      "serif": "Playfair Display",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk"
    }
  },
  "data": {
    "title": "The Future of Open Banking",
    "description": "How APIs are reshaping financial services and unlocking new revenue for enterprises globally.",
    "category": "Open Banking",
    "source": "Cateina Insights",
    "image": "https://picsum.photos/id/10/1080/1350"
  },
  "layers": [
    {
      "id": "bg",
      "type": "fill_rect",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "color": "@brand.colors.background",
      "opacity": 1
    },
    {
      "id": "cover_image",
      "type": "image_fill",
      "src": "@data.image",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "opacity": 1
    },
    {
      "id": "gradient_overlay",
      "type": "linear_gradient",
      "x1": 0,
      "y1": "$canvas.height*0.25",
      "x2": 0,
      "y2": "$canvas.height",
      "color_start": "#000000",
      "opacity_start": 0,
      "color_end": "#000000",
      "opacity_end": 0.92,
      "opacity": 1
    },
    {
      "id": "top_fade",
      "type": "linear_gradient",
      "x1": 0,
      "y1": 0,
      "x2": 0,
      "y2": "$canvas.height*0.45",
      "color_start": "#000000",
      "opacity_start": 0.75,
      "color_end": "#000000",
      "opacity_end": 0,
      "opacity": 1
    },
    {
      "id": "category_tag",
      "type": "tag",
      "content_ref": "@data.category",
      "font": "@brand.fonts.grotesk",
      "size": 18,
      "weight": 600,
      "letter_spacing": 4,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.15,
      "border": true,
      "border_opacity": 0.45,
      "padding_h": 24,
      "padding_v": 10,
      "x": 80,
      "y": 100,
      "align": "left",
      "opacity": 0
    },
    {
      "id": "title",
      "type": "text_block",
      "content_ref": "@data.title",
      "max_width": "$canvas.width-160",
      "font": "@brand.fonts.serif",
      "size": 72,
      "weight": 700,
      "color": "@brand.colors.text",
      "line_height": 84,
      "x": 80,
      "y": 220,
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "description",
      "type": "text_block",
      "content_ref": "@data.description",
      "max_width": "$canvas.width-160",
      "font": "@brand.fonts.sans",
      "size": 30,
      "weight": 300,
      "color": "@brand.colors.text",
      "color_opacity": 0.75,
      "line_height": 44,
      "x": 80,
      "y": 620,
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "divider",
      "type": "line",
      "x1": 80,
      "y1": "$canvas.height*0.92",
      "x2": "$canvas.width-80",
      "y2": "$canvas.height*0.92",
      "color": "@brand.colors.primary",
      "stroke_width": 1,
      "origin": "left",
      "opacity": 0
    },
    {
      "id": "brand_logo",
      "type": "brand_watermark",
      "font": "@brand.fonts.mono",
      "size": 18,
      "letter_spacing": 4,
      "color": "@brand.colors.text",
      "color_opacity": 0.35,
      "x": 80,
      "y": "$canvas.height*0.955",
      "align": "left",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "source_tag",
      "type": "source_tag",
      "content_ref": "@data.source",
      "prefix": "",
      "font": "@brand.fonts.mono",
      "size": 18,
      "letter_spacing": 1,
      "color": "@brand.colors.primary",
      "bg_opacity": 0,
      "border_opacity": 0,
      "padding_h": 0,
      "padding_v": 0,
      "x": "$canvas.width-80",
      "y": "$canvas.height*0.955",
      "align": "right",
      "opacity": 0
    }
  ],
  "animations": [
    {
      "layer_id": "category_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 8,
      "end_frame": 38,
      "easing": "ease_out"
    },
    {
      "layer_id": "category_tag",
      "property": "y",
      "from_value": -20,
      "to_value": 0,
      "start_frame": 8,
      "end_frame": 38,
      "easing": "ease_out"
    },
    {
      "layer_id": "title",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 28,
      "end_frame": 78,
      "easing": "ease_out"
    },
    {
      "layer_id": "title",
      "property": "y",
      "from_value": -24,
      "to_value": 0,
      "start_frame": 28,
      "end_frame": 78,
      "easing": "ease_out"
    },
    {
      "layer_id": "description",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 68,
      "end_frame": 110,
      "easing": "ease_out"
    },
    {
      "layer_id": "description",
      "property": "y",
      "from_value": -20,
      "to_value": 0,
      "start_frame": 68,
      "end_frame": 110,
      "easing": "ease_out"
    },
    {
      "layer_id": "divider",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.3,
      "start_frame": 115,
      "end_frame": 140,
      "easing": "ease_out"
    },
    {
      "layer_id": "divider",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 115,
      "end_frame": 142,
      "easing": "ease_out"
    },
    {
      "layer_id": "brand_logo",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 145,
      "end_frame": 170,
      "easing": "ease_out"
    },
    {
      "layer_id": "source_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 145,
      "end_frame": 170,
      "easing": "ease_out"
    }
  ]
}