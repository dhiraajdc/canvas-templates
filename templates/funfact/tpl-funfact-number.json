{
  "meta": {
    "template_id": "funfact-number-v1",
    "intent": "fun_fact",
    "mode": "number_fact",
    "style": "playful_number",
    "version": "3.1",
    "total_frames": 270,
    "fps": 30
  },
  "canvas": {
    "ratio": "4:5",
    "background": "#0D0D14"
  },
  "brand": {
    "logo": "FACT·DAILY",
    "colors": {
      "primary": "#F59E0B",
      "background": "#0D0D14",
      "text": "#FFFFFF",
      "muted": "#7A8599",
      "surface": "#151520"
    },
    "fonts": {
      "display": "Bebas Neue",
      "serif": "Playfair Display",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk"
    }
  },
  "data": {
    "fact_number": "10",
    "fact_unit": "M",
    "fact_label": "bacteria live on every square centimetre of your skin",
    "category": "Biology"
  },
  "layers": [
    {
      "id": "bg",
      "type": "fill_rect",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "color": "@brand.colors.background",
      "opacity": 1
    },
    {
      "id": "bg_glow",
      "type": "radial_gradient",
      "cx": "$canvas.width*0.5",
      "cy": "$canvas.height*0.42",
      "radius": 500,
      "color_start": "@brand.colors.primary",
      "opacity_start": 0.12,
      "color_end": "@brand.colors.primary",
      "opacity_end": 0,
      "opacity": 1
    },
    {
      "id": "dot_grid",
      "type": "dot_grid",
      "spacing": 72,
      "dot_radius": 2,
      "color": "@brand.colors.primary",
      "opacity": 0.06
    },
    {
      "id": "vignette",
      "type": "vignette",
      "inner_radius": 200,
      "outer_radius": 900,
      "color": "#000000",
      "strength": 0.5,
      "opacity": 0
    },
    {
      "id": "cat_tag",
      "type": "tag",
      "content_ref": "@data.category",
      "font": "@brand.fonts.grotesk",
      "size": 18,
      "weight": 600,
      "letter_spacing": 4,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.1,
      "border": true,
      "border_opacity": 0.35,
      "padding_h": 28,
      "padding_v": 12,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.12",
      "align": "center",
      "opacity": 0
    },
    {
      "id": "main_number",
      "type": "number_display",
      "value_ref": "@data.fact_number",
      "count_up": true,
      "font": "@brand.fonts.display",
      "size": 240,
      "color": "@brand.colors.text",
      "unit_text": "@data.fact_unit",
      "unit_size": 72,
      "unit_font": "@brand.fonts.grotesk",
      "unit_weight": 500,
      "unit_color": "@brand.colors.primary",
      "unit_offset_x": 16,
      "unit_offset_y": 190,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.46",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "rule",
      "type": "divider_ornament",
      "x1": 108,
      "x2": "$canvas.width-108",
      "y": "$canvas.height*0.595",
      "gap": 10,
      "stroke_width": 1,
      "color": "@brand.colors.primary",
      "centre": "diamond",
      "centre_size": 10,
      "inner_gap": 24,
      "opacity": 0
    },
    {
      "id": "fact_label",
      "type": "text_block",
      "content_ref": "@data.fact_label",
      "max_width": "$canvas.width-180",
      "font": "@brand.fonts.sans",
      "size": 34,
      "weight": 300,
      "color": "@brand.colors.text",
      "color_opacity": 0.7,
      "line_height": 52,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.64",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "brand_logo",
      "type": "brand_watermark",
      "font": "@brand.fonts.mono",
      "size": 17,
      "letter_spacing": 5,
      "color": "@brand.colors.muted",
      "color_opacity": 0.35,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.94",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    }
  ],
  "animations": [
    {
      "layer_id": "vignette",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 0,
      "end_frame": 30,
      "easing": "ease_out"
    },
    {
      "layer_id": "cat_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 8,
      "end_frame": 35,
      "easing": "ease_out"
    },
    {
      "layer_id": "main_number",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 22,
      "end_frame": 58,
      "easing": "ease_out"
    },
    {
      "layer_id": "main_number",
      "property": "count_progress",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 22,
      "end_frame": 85,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 95,
      "end_frame": 118,
      "easing": "ease_out"
    },
    {
      "layer_id": "rule",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 95,
      "end_frame": 120,
      "easing": "ease_out"
    },
    {
      "layer_id": "fact_label",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 112,
      "end_frame": 152,
      "easing": "ease_out"
    },
    {
      "layer_id": "fact_label",
      "property": "y",
      "from_value": 18,
      "to_value": 0,
      "start_frame": 112,
      "end_frame": 152,
      "easing": "ease_out"
    },
    {
      "layer_id": "brand_logo",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 228,
      "end_frame": 252,
      "easing": "ease_out"
    }
  ]
}