{
  "meta": {
    "template_id": "funfact-mind-blown-v1",
    "intent": "fun_fact",
    "mode": "mind_blown",
    "style": "setup_twist",
    "version": "3.1",
    "total_frames": 270,
    "fps": 30
  },
  "canvas": {
    "ratio": "4:5",
    "background": "#0D0D14"
  },
  "brand": {
    "logo": "FACT·DAILY",
    "colors": {
      "primary": "#F59E0B",
      "background": "#0D0D14",
      "text": "#FFFFFF",
      "muted": "#7A8599",
      "surface": "#151520"
    },
    "fonts": {
      "display": "Bebas Neue",
      "serif": "Playfair Display",
      "sans": "DM Sans",
      "mono": "DM Mono",
      "grotesk": "Space Grotesk"
    }
  },
  "data": {
    "setup": "Oxford University is older than the Aztec Empire",
    "twist": "Teaching began at Oxford in 1096. The Aztec Empire was not founded until 1428.",
    "category": "History",
    "source": "Encyclopaedia Britannica"
  },
  "layers": [
    {
      "id": "bg",
      "type": "fill_rect",
      "x": 0,
      "y": 0,
      "width": "$canvas.width",
      "height": "$canvas.height",
      "color": "@brand.colors.background",
      "opacity": 1
    },
    {
      "id": "bg_glow",
      "type": "radial_gradient",
      "cx": "$canvas.width*0.5",
      "cy": "$canvas.height*0.4",
      "radius": 480,
      "color_start": "@brand.colors.primary",
      "opacity_start": 0.09,
      "color_end": "@brand.colors.primary",
      "opacity_end": 0,
      "opacity": 1
    },
    {
      "id": "vignette",
      "type": "vignette",
      "inner_radius": 200,
      "outer_radius": 900,
      "color": "#000000",
      "strength": 0.5,
      "opacity": 0
    },
    {
      "id": "cat_tag",
      "type": "tag",
      "content_ref": "@data.category",
      "font": "@brand.fonts.grotesk",
      "size": 18,
      "weight": 600,
      "letter_spacing": 4,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.1,
      "border": true,
      "border_opacity": 0.35,
      "padding_h": 28,
      "padding_v": 12,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.11",
      "align": "center",
      "opacity": 0
    },
    {
      "id": "setup",
      "type": "text_block",
      "content_ref": "@data.setup",
      "max_width": "$canvas.width-160",
      "font": "@brand.fonts.serif",
      "size": 68,
      "weight": 700,
      "color": "@brand.colors.text",
      "line_height": 86,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.245",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "pause_line_l",
      "type": "line",
      "x1": 90,
      "y1": "$canvas.height*0.56",
      "x2": "$canvas.width*0.43",
      "y2": "$canvas.height*0.56",
      "color": "@brand.colors.primary",
      "stroke_width": 1,
      "origin": "center",
      "opacity": 0
    },
    {
      "id": "pause_diamond",
      "type": "diamond",
      "cx": "$canvas.width*0.5",
      "cy": "$canvas.height*0.56",
      "size": 14,
      "color": "@brand.colors.primary",
      "opacity": 0
    },
    {
      "id": "pause_line_r",
      "type": "line",
      "x1": "$canvas.width*0.57",
      "y1": "$canvas.height*0.56",
      "x2": "$canvas.width-90",
      "y2": "$canvas.height*0.56",
      "color": "@brand.colors.primary",
      "stroke_width": 1,
      "origin": "center",
      "opacity": 0
    },
    {
      "id": "twist",
      "type": "text_block",
      "content_ref": "@data.twist",
      "max_width": "$canvas.width-180",
      "font": "@brand.fonts.sans",
      "size": 34,
      "weight": 300,
      "color": "@brand.colors.primary",
      "line_height": 52,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.618",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    },
    {
      "id": "source_tag",
      "type": "source_tag",
      "content_ref": "@data.source",
      "prefix": "SOURCE: ",
      "font": "@brand.fonts.mono",
      "size": 18,
      "letter_spacing": 1,
      "color": "@brand.colors.primary",
      "bg_opacity": 0.08,
      "border_opacity": 0.2,
      "padding_h": 28,
      "padding_v": 12,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.875",
      "align": "center",
      "opacity": 0
    },
    {
      "id": "brand_logo",
      "type": "brand_watermark",
      "font": "@brand.fonts.mono",
      "size": 17,
      "letter_spacing": 5,
      "color": "@brand.colors.muted",
      "color_opacity": 0.35,
      "x": "$canvas.width*0.5",
      "y": "$canvas.height*0.94",
      "align": "center",
      "baseline": "alphabetic",
      "opacity": 0
    }
  ],
  "animations": [
    {
      "layer_id": "vignette",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 0,
      "end_frame": 30,
      "easing": "ease_out"
    },
    {
      "layer_id": "cat_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 8,
      "end_frame": 35,
      "easing": "ease_out"
    },
    {
      "layer_id": "setup",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 22,
      "end_frame": 75,
      "easing": "ease_out"
    },
    {
      "layer_id": "setup",
      "property": "y",
      "from_value": 24,
      "to_value": 0,
      "start_frame": 22,
      "end_frame": 75,
      "easing": "ease_out"
    },
    {
      "layer_id": "pause_line_l",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.5,
      "start_frame": 88,
      "end_frame": 112,
      "easing": "ease_out"
    },
    {
      "layer_id": "pause_line_l",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 88,
      "end_frame": 114,
      "easing": "ease_out"
    },
    {
      "layer_id": "pause_diamond",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 92,
      "end_frame": 115,
      "easing": "elastic_out"
    },
    {
      "layer_id": "pause_diamond",
      "property": "scale",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 92,
      "end_frame": 118,
      "easing": "elastic_out"
    },
    {
      "layer_id": "pause_line_r",
      "property": "opacity",
      "from_value": 0,
      "to_value": 0.5,
      "start_frame": 88,
      "end_frame": 112,
      "easing": "ease_out"
    },
    {
      "layer_id": "pause_line_r",
      "property": "scale_x",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 88,
      "end_frame": 114,
      "easing": "ease_out"
    },
    {
      "layer_id": "twist",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 125,
      "end_frame": 165,
      "easing": "ease_out"
    },
    {
      "layer_id": "twist",
      "property": "y",
      "from_value": 20,
      "to_value": 0,
      "start_frame": 125,
      "end_frame": 165,
      "easing": "ease_out"
    },
    {
      "layer_id": "source_tag",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 185,
      "end_frame": 210,
      "easing": "ease_out"
    },
    {
      "layer_id": "brand_logo",
      "property": "opacity",
      "from_value": 0,
      "to_value": 1,
      "start_frame": 205,
      "end_frame": 228,
      "easing": "ease_out"
    }
  ]
}